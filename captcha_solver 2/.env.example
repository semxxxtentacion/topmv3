# 2Captcha / Rucaptcha API key (одинаковый формат)
# Регистрация: https://rucaptcha.com/  (или 2captcha.com — англ. версия)
CAPTCHA_API_KEY=your_api_key_here

# Какой сервис использовать (rucaptcha.com или 2captcha.com)
CAPTCHA_SERVICE_HOST=rucaptcha.com

# Опционально: прокси для встроенного Chromium солвера (http://user:pass@host:port или socks5://host:port)
# HTTP_PROXY=

# Polling настройки 2Captcha (как часто опрашивать готов ли результат)
CAPTCHA_POLL_INTERVAL=3
CAPTCHA_POLL_MAX_TRIES=40

# REST API сервер
HOST=0.0.0.0
PORT=8080

# gRPC сервер
GRPC_PORT=50051

# Браузер встроенного solver'а (true для прода, false для отладки)
HEADLESS=true

# === ОТЛАДКА ===
# Сколько секунд держать окно браузера открытым после решения (для визуальной проверки)
# KEEP_OPEN_SECONDS=0
# Отключить anti-detect (для теста — гарантирует что Яндекс покажет капчу)
# DISABLE_STEALTH=false
