# =====================================================
# Top Machine Backend — .env шаблон
# Копировать в .env и заполнить реальными значениями.
# =====================================================

# ---- Frontend / Admin ----
FRONTEND_URL=https://topmashina.ru
ADMIN_URL=https://admin.topmashina.ru

# ---- PostgreSQL ----
DB_HOST=db
DB_PORT=5432
DB_NAME=top-machine
DB_USER=admin
DB_PASSWORD=CHANGE-ME

# ---- Bot profiles DB (acc_generator, внешняя) ----
BOT_DB_HOST=
BOT_DB_PORT=5433
BOT_DB_NAME=acc_generator
BOT_DB_USER=
BOT_DB_PASSWORD=

# ---- Bot internal ----
BOT_INTERNAL_URL=http://bot:8081/internal/notify
BOT_API_SECRET=CHANGE-ME

# ---- JWT ----
JWT_SECRET=CHANGE-ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ---- Mail (Timeweb SMTP, порт 465 — implicit TLS) ----
# Ящик должен быть создан в панели Timeweb Почта на домене topmashina.ru.
# MAIL_EMAIL = полный адрес (типа support@topmashina.ru), пароль от ящика.
MAIL_HOST=smtp.timeweb.ru
MAIL_EMAIL=support@topmashina.ru
MAIL_PASSWORD=

# ---- Tinkoff ----
TINKOFF_INIT_URL=https://securepay.tinkoff.ru/v2/Init
TINKOFF_GET_STATE_URL=https://securepay.tinkoff.ru/v2/GetState

# ---- TopVisor ----
TOPVIZOR_TOKEN=
TOPVIZOR_USER=

# ---- keys.so ----
BASE_API_KEYS_SO=https://api.keys.so/report/simple/organic/keywords
BASE_PARAMS_API_KEYS_SO=base=msk&per_page=100&sort=ws|desc

# ---- ASocks Proxy ----
ASOCKS_API_KEY=
ASOCKS_BASE_URL=https://api.asocks.com/v2

# ---- Yandex OAuth (server-side authorization code flow) ----
YANDEX_CLIENT_ID=9a0a11d361714c3089d41efaf191162c
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://topmashina.ru/yandex-oauth
